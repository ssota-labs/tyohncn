{
  "name": "@tyohn/studio",
  "version": "0.1.0",
  "description": "tyohncn Studio — catalog, theme/style inspectors, CSS export",
  "type": "module",
  "bin": {
    "tyohn-studio": "./bin/tyohn-studio.mjs"
  },
  "files": [
    "app",
    "bin",
    "components",
    "lib",
    "public",
    "scripts",
    "styles",
    "next.config.ts",
    "postcss.config.mjs",
    "tsconfig.json",
    ".next/standalone",
    ".next/static"
  ],
  "scripts": {
    "prepare-styles": "node ./scripts/prepare-style-packs.mjs",
    "predev": "pnpm prepare-styles",
    "prebuild": "pnpm prepare-styles",
    "dev": "next dev --port 3001",
    "build": "next build",
    "start": "node ./bin/tyohn-studio.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"lint: noop\"",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@hugeicons/core-free-icons": "^1.0.0",
    "@hugeicons/react": "^1.0.0",
    "@phosphor-icons/react": "^2.1.10",
    "@remixicon/react": "^4.6.0",
    "@shadcn/react": "^0.2.1",
    "@tabler/icons-react": "^3.34.0",
    "@tailwindcss/postcss": "^4.1.8",
    "@tyohn/registry": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.525.0",
    "next": "^16.0.0",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.4",
    "react": "^19.1.0",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.1.0",
    "react-resizable-panels": "^4.12.2",
    "recharts": "^3.9.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.0",
    "tailwindcss": "^4.1.8"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ssota-labs/tyohncn.git",
    "directory": "apps/studio"
  }
}
