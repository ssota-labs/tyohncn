{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "preserve",
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/components/ui/*": ["../../packages/registry/ui/*"],
      "@/components/icon-placeholder": [
        "../../packages/registry/components/icon-placeholder.tsx"
      ],
      "@/hooks/*": ["../../packages/registry/hooks/*"],
      "@/lib/utils": ["../../packages/registry/lib/utils.ts"],
      "@/*": ["./*"]
    },
    "types": ["node"]
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
