{
  "name": "@tyohn/registry",
  "version": "0.1.0",
  "description": "Base UI component registry with external cn-* style hooks for tyohncn",
  "type": "module",
  "files": [
    "ui",
    "lib",
    "hooks",
    "components",
    "styles",
    "theme",
    "manifest",
    "dist"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./theme.css": "./theme/theme.css",
    "./styles/*": "./styles/*",
    "./manifest/components.json": "./manifest/components.json",
    "./manifest/styles.json": "./manifest/styles.json",
    "./manifest/tokens.json": "./manifest/tokens.json",
    "./ui/*": "./ui/*",
    "./components/icon-placeholder": "./components/icon-placeholder.tsx",
    "./lib/utils": "./lib/utils.ts",
    "./hooks/use-mobile": "./hooks/use-mobile.ts"
  },
  "scripts": {
    "build": "node ./scripts/build-manifest.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "@base-ui/react": "^1.0.0",
    "@hugeicons/core-free-icons": ">=1.0.0",
    "@hugeicons/react": ">=1.0.0",
    "@phosphor-icons/react": ">=2.0.0",
    "@remixicon/react": ">=4.0.0",
    "@shadcn/react": ">=0.0.0",
    "@tabler/icons-react": ">=3.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "lucide-react": ">=0.400.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@hugeicons/core-free-icons": {
      "optional": true
    },
    "@hugeicons/react": {
      "optional": true
    },
    "@phosphor-icons/react": {
      "optional": true
    },
    "@remixicon/react": {
      "optional": true
    },
    "@tabler/icons-react": {
      "optional": true
    },
    "lucide-react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "next-themes": "^0.4.6",
    "react-day-picker": "^10.0.1",
    "react-resizable-panels": "^4.12.2",
    "recharts": "^3.9.2",
    "sonner": "^2.0.7",
    "typescript": "^5.8.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ssota-labs/tyohncn.git",
    "directory": "packages/registry"
  },
  "engines": {
    "node": ">=22"
  }
}
