{
  "name": "@tyohn/registry",
  "version": "0.1.0",
  "description": "Base UI component registry with external cn-* style hooks for tyohncn",
  "type": "module",
  "files": [
    "ui",
    "lib",
    "hooks",
    "styles",
    "theme",
    "manifest",
    "dist"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./theme.css": "./theme/theme.css",
    "./styles/*": "./styles/*",
    "./manifest/components.json": "./manifest/components.json",
    "./manifest/styles.json": "./manifest/styles.json",
    "./manifest/tokens.json": "./manifest/tokens.json",
    "./ui/*": "./ui/*",
    "./lib/utils": "./lib/utils.ts",
    "./hooks/use-mobile": "./hooks/use-mobile.ts"
  },
  "scripts": {
    "build": "node ./scripts/build-manifest.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "@shadcn/react": ">=0.0.0",
    "@base-ui/react": "^1.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "lucide-react": ">=0.400.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "typescript": "^5.8.3"
  }
}
